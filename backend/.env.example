# Copy this file to .env before running backend:
# cp .env.example .env

# Modes: local | github
TASKS_SYNC_MODE=local

# Used when TASKS_SYNC_MODE=local
LOCAL_TASKS_FILE_PATH=../../kumarrajdevops.github.io/daily_tasks_log.md

# Used when TASKS_SYNC_MODE=github
GITHUB_REPO_OWNER=kumarrajdevops
GITHUB_REPO_NAME=kumarrajdevops.github.io
GITHUB_TASKS_FILE_PATH=daily_tasks_log.md
GITHUB_TARGET_BRANCH=main
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE
